{
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "root": "backend",
      "routePrefix": "/_/backend",
      "framework": "express"
    }
  },
  "rewrites": [
    {
      "source": "/((?!_/backend|api/).*)",
      "destination": "/index.html"
    }
  ]
}