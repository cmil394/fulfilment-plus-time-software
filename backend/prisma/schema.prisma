generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  firstName     String
  lastName      String
  role          Role     @default(EMPLOYEE)
  status        UserStatus @default(PENDING)
  averageCost   Float?   @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  timeLogs      TimeLog[]
  weeklyReports WeeklyReport[]
  
  @@map("users")
}

model Company {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  timeLogs  TimeLog[]
  reports   CompanyReport[]
  
  @@map("companies")
}

model Activity {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  timeLogs  TimeLog[]
  
  @@map("activities")
}

model TimeLog {
  id          String    @id @default(uuid())
  userId      String
  companyId   String
  activityId  String
  startTime   DateTime
  endTime     DateTime?
  duration    Int?      // Duration in seconds
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  activity    Activity  @relation(fields: [activityId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([companyId])
  @@index([activityId])
  @@index([startTime])
  @@map("time_logs")
}

model WeeklyReport {
  id          String   @id @default(uuid())
  userId      String
  weekStart   DateTime
  weekEnd     DateTime
  totalHours  Float
  totalCost   Float?
  reportData  Json     // Stores breakdown by company/activity
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, weekStart])
  @@index([weekStart])
  @@map("weekly_reports")
}

model CompanyReport {
  id          String   @id @default(uuid())
  companyId   String
  weekStart   DateTime
  weekEnd     DateTime
  totalHours  Float
  totalCost   Float?
  reportData  Json     // Stores breakdown by employee/activity
  createdAt   DateTime @default(now())
  
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  @@unique([companyId, weekStart])
  @@index([weekStart])
  @@map("company_reports")
}

enum Role {
  ADMIN
  TEAM_MANAGER
  WH_MANAGER
  PICKER
  EMPLOYEE
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}