generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

// Users/Authentication
model User {
  id           String      @id @default(uuid())
  email        String      @unique
  password     String
  fullName     String
  firstName    String
  lastName     String
  employeeCode String?     @unique
  pin          String?
  role         Role        @default(Employee)
  status       UserStatus  @default(PENDING)
  //hourlyRate Decimal?   @db.Decimal(10, 2)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  timeEntries  TimeEntry[]

  @@map("users")
}

// Customers
model Customer {
  id        String   @id @default(uuid())
  name      String
  ownerName String
  email     String?
  phone     String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks       Task[]
  timeEntries TimeEntry[]

  @@map("customers")
}

// Tasks (belongs to customer)
model Task {
  id          String      @id @default(uuid())
  customerId  String
  name        String
  description String?
  //fixedRate   Decimal? @db.Decimal(10, 2) 
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  timeEntries TimeEntry[]

  @@index([customerId])
  @@map("tasks")
}

// Task presets to copy to customers
model TaskTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("task_templates")
}

// Time Entries
model TimeEntry {
  id              String    @id @default(uuid())
  userId          String
  customerId      String
  taskId          String
  startTime       DateTime  @default(now())
  endTime         DateTime? // NULL = timer still running
  durationSeconds Int? // Calculated when timer stops
  notes           String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id])
  task     Task     @relation(fields: [taskId], references: [id])

  @@index([userId])
  @@index([customerId])
  @@index([taskId])
  @@index([startTime])
  @@index([endTime])
  @@map("time_entries")
}

enum Role {
  Owner
  Admin
  Employee
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

